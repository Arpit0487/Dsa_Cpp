class Solution {
public:
    int minElement(vector<int>& nums) {
        int ans = INT_MAX;
        for(int i=0; i<nums.size(); i++){
            string n = to_string(nums[i]);
            int curr = 0;
            for(auto x : n){
                curr += x-'0';
            }
            ans = min(ans,curr);
        }
        return ans;
    }
};
