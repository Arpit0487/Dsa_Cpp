class Solution {
public:
    string makeGood(string s) {
        string result;
        stack<char>st;
       for(auto ch :s){
        if(!st.empty() && abs(ch-st.top())==32) st.pop();
        else st.push(ch);
       }
       while(!st.empty()){
        result+=st.top();
        st.pop();
       }
        reverse(result.begin(),result.end());
        return result;
    }
};
