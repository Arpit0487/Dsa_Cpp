class Solution {
public:
    int longestSubarray(vector<int>& nums) {
        int n = *max_element(nums.begin(),nums.end());
        int curr = 0;
        int temp = 0;
        for(int i=0; i<nums.size(); i++){
            if(nums[i]==n) temp++;
            else temp=0;
            curr=max(curr,temp);
        }
        return curr;
    }
};
