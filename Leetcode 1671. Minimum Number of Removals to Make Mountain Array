class Solution {
public:
    void LIS_left(vector<int>& nums, vector<int>& dp) {
        int n = nums.size();
        for(int i=0; i<n; i++) {
            for(int j=0; j<i; j++) {
                if(nums[j] < nums[i]) {
                    dp[i] = max(dp[i], 1 + dp[j]);
                }
            }
        }
    }

    void LIS_right(vector<int>& nums, vector<int>& dp) {
        int n = nums.size();
        for(int i=n-1; i>=0; i--) {
            for(int j=n-1; j>i; j--) {
                if(nums[j] < nums[i]) {
                    dp[i] = max(dp[i], 1 + dp[j]);
                }
            }
        }
    }

    int minimumMountainRemovals(vector<int>& nums) {
        int n = nums.size();

        vector<int> left(n, 1);   
        vector<int> right(n, 1);  

        LIS_left(nums, left);
        LIS_right(nums, right);

        int maxi = 0;

        for(int i = 1; i < n - 1; i++) {
            if(left[i] > 1 && right[i] > 1) {
                maxi = max(maxi, left[i] + right[i] - 1);
            }
        }

        return n - maxi;
    }
};
