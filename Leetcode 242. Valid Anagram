class Solution {
public:
    bool isAnagram(string s, string t) {
        vector<int> freq(26); //creating a frequency array of 26 length to store frequency of each letter
        for(char ch:s) freq[ch-'a']++; //adding frequency on the basis of 1st string
        for(char ch:t) freq[ch-'a']--; //subtracting on the basis of 2nd string
        return count(freq.begin(),freq.end(),0)==26; 
        //at the end if they are anagram frequencies sum should be 0 after adding and removing
        //count the zeros in the frequency array if total no of zeros are 26 which means they are anagram
    }
};
