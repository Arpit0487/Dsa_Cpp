
class Solution {
  public:
    int countDer(int n) {
        if(n<=2) return n-1;
        vector<long long> dp(n+3);
        const long long mod = 1e9+7;
        dp[0]=0;
        dp[1]=1;
        for(int i=1; i<=n; i+=2){
            dp[i+1] = ((i+2) * dp[i] - 1 + mod) % mod;
            dp[i+2] = ((i+3) * dp[i+1] + 1) % mod;
        }
        return dp[n-1];
    }
};
