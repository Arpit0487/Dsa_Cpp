class Solution {
public:
    int minimumSwaps(vector<int>& nums) {
        int count = 0;
        int swapCount = 0;
        for(auto x : nums) if(x==0) count++;
        int idx = nums.size()-1;
        while(count--){
            if(nums[idx]!=0) swapCount++;
            idx--;
        }
        return swapCount;
    }
};
