class Solution {
public:
    int decimal(string binary) {
        int dec = 0;
        for(char c : binary){
            dec = dec * 2 + (c - '0');
        }
        return dec;
    }
    int bitwiseComplement(int n) {
        if(n == 0) return 1;
        string ans;
        while (n) {
            int x = n % 2;
            n /= 2;
            if (x == 0)
                ans.push_back('1');
            else
                ans.push_back('0');
        }
        reverse(ans.begin(), ans.end());
        return decimal(ans);
    }
};
