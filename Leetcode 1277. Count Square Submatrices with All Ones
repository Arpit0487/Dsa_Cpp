class Solution {
public:
    int countSquares(vector<vector<int>>& matrix) {
        int count = 0;
        for(int i=0; i<matrix.size(); i++){

            for(int j=0; j<matrix[0].size(); j++){
                if(i==0 || j==0){
                    count+=matrix[i][j];
                    continue;
                }
                //if not then check current ij is 1
                if(matrix[i][j]==1){
                    if(matrix[i][j-1]>=1 && matrix[i-1][j]>=1 && matrix[i-1][j-1]>=1){
                        matrix[i][j] += min(matrix[i][j-1], min(matrix[i-1][j],matrix[i-1][j-1]));
                        count += (matrix[i][j]-1);
                    }
                    count++;
                }
            }
        }
        return count;
    }
};
