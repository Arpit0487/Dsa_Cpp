class Solution {
public:
    vector<int> constructTransformedArray(vector<int>& nums) {
        vector<int> ans;
        int n = nums.size();
        for(int i=0; i<n; i++){
            if(nums[i]>0){
                int idx = (i + nums[i])%n;
                ans.push_back(nums[idx]);
            }
            else if(nums[i]<0){
                int idx = (i + nums[i])%n;
                if(idx < 0) idx += n;
                ans.push_back(nums[idx]);
            }
            else{
                ans.push_back(nums[i]);
            }
        }
        return ans;
    }
};
