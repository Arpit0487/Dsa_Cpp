class Solution {
public:
    ListNode* swapPairs(ListNode* head) {
        ListNode* dummy = new ListNode(0);
        dummy->next = head;
        ListNode* prev = dummy;
        while(prev->next && prev->next->next){
            ListNode* a = prev->next;
            ListNode* b = a->next;
            ListNode* nextptr = b->next;

            prev->next = b;
            b->next = a;
            a->next = nextptr;
            prev = a;
        }
        return dummy->next;
    }
};
