class Solution {
public:
    int minAbsoluteDifference(vector<int>& nums) {
        int diff = INT_MAX;
        bool flag = false;
        for(int i=0; i<nums.size(); i++){
            if(nums[i]==0) continue;
            for(int j=i+1; j<nums.size(); j++){
                if(nums[i]==1 && nums[j]==2){
                    diff = min(diff,abs(i-j));
                    flag=true;
                }
                if(nums[i]==2 && nums[j]==1){
                    diff = min(diff,abs(i-j));
                    flag=true;
                }
            }
        }
        if(flag) return diff;
        return -1;
    }
};
