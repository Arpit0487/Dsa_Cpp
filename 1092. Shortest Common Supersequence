class Solution {
public:
    string lcs(string &a, string &b) {
        int m = a.size(), n = b.size();
        vector<vector<int>> dp(m+1, vector<int>(n+1, 0));

        // Proper 1-based DP filling
        for(int i = 1; i <= m; i++){
            for(int j = 1; j <= n; j++){
                if(a[i-1] == b[j-1])
                    dp[i][j] = 1 + dp[i-1][j-1];
                else
                    dp[i][j] = max(dp[i-1][j], dp[i][j-1]);
            }
        }

        // Reconstruct LCS
        string res = "";
        int i = m, j = n;

        while(i > 0 && j > 0){
            if(a[i-1] == b[j-1]){
                res.push_back(a[i-1]);
                i--; j--;
            }
            else if(dp[i-1][j] > dp[i][j-1]) i--;
            else j--;
        }

        reverse(res.begin(), res.end());
        return res;
    }

    string shortestCommonSupersequence(string a, string b) {
        string l = lcs(a, b);

        int i = 0, j = 0;
        string scs = "";

        for(char c : l){
            while(a[i] != c) scs += a[i++];
            while(b[j] != c) scs += b[j++];
            scs += c;
            i++; j++;
        }

        // add remaining
        scs += a.substr(i);
        scs += b.substr(j);

        return scs;
    }
};
