class Solution {
public:
    vector<vector<int>> dp;
    int sum = 0;

    int helper(int i, vector<int>& nums, int target) {
        if (i == nums.size()) {
            return target == 0;
        }

        if (target + sum < 0 || target + sum >= 2 * sum + 1) return 0;

        if (dp[i][target + sum] != -1) return dp[i][target + sum];

        int add = helper(i + 1, nums, target + nums[i]);
        int sub = helper(i + 1, nums, target - nums[i]);

        return dp[i][target + sum] = add + sub;
    }

    int findTargetSumWays(vector<int>& nums, int target) {
        for (auto x : nums) sum += x;

        dp.assign(nums.size(), vector<int>(2 * sum + 1, -1));

        return helper(0, nums, target);
    }
};
