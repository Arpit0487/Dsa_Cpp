class Solution {
public:
    vector<int> leftRightDifference(vector<int>& nums) {
        int n = nums.size();
        vector<int> ans;
        int sum = accumulate(nums.begin(),nums.end(),0);
        int lsum = 0;
        int rsum = sum;
        for(int i=0; i<n; i++){
            rsum-=nums[i];
            ans.push_back(abs(lsum-rsum));
            lsum+=nums[i];
        }
        return ans;
    }
};
