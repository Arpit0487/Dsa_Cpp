class Solution {
public:
    bool uniformArray(vector<int>& nums1) {
        int min_odd = INT_MAX;
        int min_even = INT_MAX;
        //check if all even
        bool odd = false;
        bool even = false;
        for(auto x: nums1){
            if(x%2!=0){
                odd = true;
                min_odd = min(min_odd,x);
            }
            else{
                even = true;
                min_even = min(min_even,x);
            }
        }
        if(odd==true && even==false || odd==false && even==true) return true;
        if(min_odd<min_even) return true;
        return false;
    }
};
