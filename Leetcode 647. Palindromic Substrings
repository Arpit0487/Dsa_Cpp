class Solution {
public:
    int countSubstrings(string s) {
       int count = 0;
       int n = s.length();
       vector<vector<int>> dp(n,vector<int>(n));

        for(int k=0; k<n; k++){
            int i=0, j=k;
            while(j<n){
                if(i==j){
                    dp[i][j]=1;
                    count++;
                }
                else if(s[i]==s[j] && j==i+1){
                    dp[i][j]=1;
                    count++;
                }
                else if(s[i]==s[j] && dp[i+1][j-1]==1){
                    dp[i][j]=1;
                    count++;
                }
                i++; j++;
            }
        }

        return count;
    }
};
