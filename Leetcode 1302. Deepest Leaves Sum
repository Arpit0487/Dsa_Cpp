class Solution {
public:
    int maxDepth(TreeNode* root){
        if(root==nullptr) return 0;
        return 1+max(maxDepth(root->left),maxDepth(root->right));
    }

    void helper(TreeNode* root, int lvl, int a, int& sum){
        if(root==nullptr) return;
        if(lvl==a) sum+=root->val;
        helper(root->left,lvl+1,a,sum);
        helper(root->right,lvl+1,a,sum);
    }

    int deepestLeavesSum(TreeNode* root) {
        int a = maxDepth(root);
        int sum = 0;
        helper(root,1,a,sum);
        return sum;
    }
};
