class Solution {
public:
    string longestPalindrome(string s) {
        int n = s.length();
        if(n==1) return s;
        vector<vector<int>> dp(n, vector<int>(n));
        int a=-1, b=-1;
        for (int k=0; k<n; k++) {
            int i=0, j=k;
            while (j<n) {
                if (i == j) {
                    dp[i][j] = 1;
                    a=i;
                    b=j;
                } 
                else if (s[i] == s[j] && j == i + 1) {
                    dp[i][j] = 1;
                    a=i;
                    b=j;
                } 
                else if (s[i] == s[j] && dp[i + 1][j - 1] == 1) {
                    dp[i][j] = 1;
                    a=i;
                    b=j;
                }
                i++;
                j++;
            }
        }
        return s.substr(a,b-a+1);
    }
};
