class Solution {
public:
    vector<vector<long>> dp;

    long helper(int i, vector<int>& coins, int amount){
        if(i==coins.size()){
            if(amount==0) return 1;
            else return 0;
        }
        if(dp[i][amount]!=-1) return dp[i][amount];
        long skip = helper(i+1,coins,amount);
        long take = 0;
        if(coins[i] <= amount) take = helper(i,coins,amount-coins[i]);
        return dp[i][amount] = take + skip;
    }

    int change(int amount, vector<int>& coins) {
        dp.assign(coins.size(), vector<long>(amount + 1, -1));
        return helper(0,coins,amount);
    }
};
