class Solution {
public:
    vector<int> corpFlightBookings(vector<vector<int>>& bookings, int n) {
        vector<int> ans(n,0);
        for(int i=0; i<bookings.size(); i++){
            int f = bookings[i][0] - 1;
            int l = bookings[i][1] - 1;
            while(f<=l){
                ans[f] += bookings[i][2];
                f++;
            }
        }
        return ans;
    }
};
