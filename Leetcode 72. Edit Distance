class Solution {
public:
    int minDistance(string word1, string word2) {
        int m = word1.length();
        int n = word2.length();
        if(m==0) return n;
        if(n==0) return m;
        vector<vector<int>> dp(m,vector<int>(n));
        for(int i=0; i<m; i++){
            for(int j=0; j<n; j++){
                int p = (i>0 && j>0) ? dp[i-1][j-1] : (i==0 ? j : i);
                int q = (i>0) ? dp[i-1][j] : j;
                int r = (j>0) ? dp[i][j-1] : i;
                if(word1[i]==word2[j]) dp[i][j] = p;
                else dp[i][j] = 1 + min(p,min(q,r));
            } 
        }
        return dp[m-1][n-1];
    }
};
