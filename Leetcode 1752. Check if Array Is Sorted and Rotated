class Solution {
public:
    bool check(vector<int>& nums) {
        vector<int> sorted = nums; // creating copy of nums
        sort(sorted.begin(),sorted.end()); //sorting it
        if(nums==sorted) return true; //if the nums is also sorted return true
        int n = nums.size()-1;
        while(n--){ //checking all possible structures of sorted
            int start = sorted[0];//rotating by each possible index 1 by 1
            for(int i=0; i<sorted.size()-1; i++){
                sorted[i]=sorted[i+1];
            }
            sorted[sorted.size()-1]=start; //adding the first element at the last
            if(sorted==nums) return true;//checking if equal of not
        }
        return false;//if still not equal to any structure after every possible rotations return false
    }
};
