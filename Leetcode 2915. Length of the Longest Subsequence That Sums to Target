class Solution {
public:
    vector<vector<int>> dp;
    int helper(int i, vector<int>& nums, int target){
        if(i==nums.size()){
            if(target==0) return 0;
            else return INT_MIN;
        }
        if(dp[i][target]!=-1) return dp[i][target];
        int skip = helper(i+1,nums,target);
        if(target<nums[i]) return skip;
        int take = 1 + helper(i+1,nums,target-nums[i]);
        return dp[i][target] =  max(take,skip);
    }
    int lengthOfLongestSubsequence(vector<int>& nums, int target) {
        dp.assign(nums.size(),vector<int>(target+1,-1));
        int ans = helper(0,nums,target);
        if(ans<-1) return -1;
        return ans;
    }
};
