class Solution {
public:
    int maxProductPath(vector<vector<int>>& grid) {
        int m = grid.size();
        int n = grid[0].size();
        vector<vector<pair<long long,long long>>> dp(m,vector<pair<long long,long long>>(n));
        
        dp[0][0] = {grid[0][0],grid[0][0]};

        for(int i=1; i<n; i++){
            long long val = dp[0][i-1].first * grid[0][i];
            dp[0][i] = {val,val};
        }

        for(int i=1; i<m; i++){
            long long val = dp[i-1][0].first * grid[i][0];
            dp[i][0] = {val, val};
        }

        for(int i=1; i<m; i++){
            for(int j=1; j<n; j++){
                long long val = grid[i][j];
                vector<long long> combis = {
                    dp[i][j-1].first * val,
                    dp[i][j-1].second * val,
                    dp[i-1][j].first * val,
                    dp[i-1][j].second * val
                };
                long long mx = *max_element(combis.begin(),combis.end());
                long long mn = *min_element(combis.begin(),combis.end());
                dp[i][j] = {mx,mn};
            }
        }
        long long ans = dp[m-1][n-1].first;
        if(ans < 0) return -1;
        return ans % 1000000007;
    }
};
