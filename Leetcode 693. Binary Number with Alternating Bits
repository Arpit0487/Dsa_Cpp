class Solution {
public:
    bool hasAlternatingBits(int n) {
        long long x = n^(n>>1);
        // n>>1 changes the value opposite to current
        // n=101010
        // n>>1 = 010101
        //xor(^) of 101010 ^ 010101 = 111111
        return (x & (x + 1)) == 0;
        //x = 111111
        //x+1 = 1000000
        //AND(&) of 111111 & 1000000 = 0
        //if 0 then true else false
    }
};
