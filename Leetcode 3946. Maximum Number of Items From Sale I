class Solution {
public:
    int maximumSaleItems(vector<vector<int>>& items, int budget) {
        int n = items.size();

        vector<int> freq(n,0);
        for(int i=0; i<n; i++){
            for(int j=0; j<n; j++){
                if(i!=j && items[j][0] % items[i][0]==0) freq[i]++;
            }
        }

        vector<int> dp(budget+1,0);

        for(int i=0; i<n; i++){
            int price = items[i][1];
            vector<int> ndp = dp;

            for(int b = 0; b+price<=budget; b++){
                ndp[b+price] = max(ndp[b+price],dp[b]+1+freq[i]);
            }

            for(int b = price; b<=budget; b++){
                ndp[b] = max(ndp[b],ndp[b-price]+1);
            }

            dp.swap(ndp);
        }

        return *max_element(dp.begin(),dp.end());
    }
};
