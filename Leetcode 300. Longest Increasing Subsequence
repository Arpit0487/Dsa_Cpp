class Solution {
public:
    int lengthOfLIS(vector<int>& nums) {
        int maxi = 0;
        int n = nums.size();
        if(n==1) return 1;
        vector<int> dp(n,1);
        for(int i=0; i<n; i++){
            for(int j=i-1; j>=0; j--){
                if(nums[j]<nums[i]){
                    dp[i]=max(dp[i],1+dp[j]);
                }
                maxi = max(maxi,dp[i]);
            }
        }
        return maxi;
    }
};
